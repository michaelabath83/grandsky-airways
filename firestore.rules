rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email in ["admin@grandskyairways.com"];
    }

    // Users: read own profile only
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Bookings: user reads own, admin reads all
    match /bookings/{bookingId} {
      allow read: if request.auth.uid == resource.data.userId || isAdmin();
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.userId || isAdmin();
    }

    // Payments: user creates own, admin reads/writes all
    match /payments/{paymentId} {
      allow create: if request.auth != null;
      allow read, update: if isAdmin();
    }

    // Tickets: user reads own (by bookingId lookup), admin full access
    match /tickets/{ticketId} {
      allow read: if isAdmin() ||
                     (request.auth != null &&
                      get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Admin-only collections
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /emailQueue/{emailId} {
      allow read, write: if isAdmin();
    }

    // Public read for flights and airports
    match /flights/{flightId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /airports/{airportId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /airlines/{airlineId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
